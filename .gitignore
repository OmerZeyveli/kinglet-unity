# ── OS cruft ──────────────────────────────────
.DS_Store
._*
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Editor / IDE ──────────────────────────────
.vscode/
.idea/
.worktrees/
*.swp
*.swo
*~

# ── Logs / temp / backups ─────────────────────
*.log
*.tmp
*.bak
*.orig

# ── Python caches ───────────────────────────────
__pycache__/
*.py[cod]

# ── Secrets (savunma amaçlı; repo'da olmamalı) ─
.env
.env.*

# ── Repo İÇİNDE test Unity projesi açarsan aç ──
# (tercihen ayrı projede test et; gerekirse bunları aç)
# [Ll]ibrary/
# [Tt]emp/
# [Oo]bj/
# [Bb]uild/

# Claude Code local settings and hook/session state.
# This repo is itself a Claude Code project, so its own hooks write here while the tests run.
.claude/settings.local.json
.claude/state/*
!.claude/state/.gitkeep
.kinglet/local/
